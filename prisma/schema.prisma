generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  APPLICANT
  AGENT
  ADMIN
}

enum PropertyType {
  APARTMENT
  HOUSE
  LAND
  COMMERCIAL
}

enum PropertyStatus {
  AVAILABLE
  SOLD
  RENTED
}

enum ModerationStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
  EXPIRED
  ARCHIVED
}

enum ResponseType {
  EMAIL
  WHATSAPP
  PHONE
}

enum NotificationType {
  LISTING_APPROVED
  LISTING_REJECTED
  LISTING_EXPIRING
  PRICE_DROP
  SAVED_SEARCH_MATCH
  SYSTEM
  KYC_VERIFIED
  KYC_REJECTED
}

enum UserType {
  PROPERTY_OWNER
  AGENT
  FUNDI
  SERVICE_PROVIDER
}

enum ListingPurpose {
  FOR_SALE
  FOR_RENT_LONG_TERM
  FOR_RENT_SHORT_TERM
}

enum PricePeriod {
  TOTAL
  PER_MONTH
  PER_NIGHT
  PER_WEEK
  PER_SQM
}

model User {
  id                String    @id @default(uuid())
  email             String?   @unique
  emailVerified     DateTime?
  passwordHash      String?
  firstName         String
  lastName          String
  role              Role      @default(APPLICANT)
  phone             String?
  phoneVerified     Boolean   @default(false)
  avatar            String?
  passportPhoto     String?
  businessLogo      String?

  failedLoginAttempts Int      @default(0)
  lockedUntil       DateTime?
  lastLogin         DateTime?
  lastActivity      DateTime?
  lastFailedLogin   DateTime?

  twoFactorSecret   String?
  twoFactorEnabled  Boolean   @default(false)

  location         String?
  propertyInterest String[]
  isAgent          Boolean   @default(false)
  agentLicense     String?
  agencyName       String?
  notificationPrefs Json?
  onboardingComplete Boolean @default(false)

  kycStatus        String    @default("NONE")
  accountStatus    String    @default("PENDING_APPROVAL")
  approvedAt       DateTime?
  approvedBy       String?

  companyName      String?
  contactPerson    String?
  category         String?
  specialties      String[]
  website          String?
  estateSubLocation String?

  address          String?
  city             String?
  postalCode       String?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  referralPartner         ReferralPartner?  @relation(fields: [referralPartnerId], references: [id], onDelete: SetNull)
  referralPartnerId       String?

  properties       Property[]
  auditLogs        AuditLog[]
  accounts         Account[]
  sessions         Session[]
  notifications    Notification[]
  refreshTokens    RefreshToken[]
  magicLinkTokens  MagicLinkToken[]
  kycDocuments     KycDocument[]
  serviceListings  ServiceListing[]
  reviews          Review[]
  commissions      Commission[]

  @@map("users")
}

model ReferralPartner {
  id                  String             @id @default(uuid())
  fullName            String
  email               String             @unique
  phone               String
  partnerCode         String             @unique
  passwordHash        String?
  passwordChangedAt   DateTime?
  mustChangePassword  Boolean            @default(false)
  status              String             @default("ACTIVE")
  suspendedReason     String?
  suspendedAt         DateTime?
  reactivatedAt       DateTime?
  referredByPartnerId String?
  totalReferrals      Int                @default(0)
  successfulReferrals Int                @default(0)
  commissionRate      Decimal            @default(3) @db.Decimal(5, 2)
  totalEarned         Decimal            @default(0) @db.Decimal(12, 2)
  totalPaid           Decimal            @default(0) @db.Decimal(12, 2)
  bankAccountName     String?
  bankAccountNumber   String?
  bankName            String?
  bankBranch          String?
  bankCode            String?
  mpesaPhone          String?
  payoutMethod        String             @default("MPESA")
  notes               String?
  lastLoginAt         DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  users            User[]
  referredPartners ReferralPartner[] @relation("PartnerReferrals")
  parentPartner    ReferralPartner?  @relation("PartnerReferrals", fields: [referredByPartnerId], references: [id])
  commissions      Commission[]
  payouts          Payout[]
  disputes         Dispute[]
  paymentClaims    PaymentClaim[]

  @@index([partnerCode])
  @@index([email])
  @@index([status])
  @@map("referral_partners")
}

model KycDocument {
  id              String    @id @default(uuid())
  userId          String
  documentType    String
  documentNumber  String?
  status          String    @default("PENDING")
  frontImage      String?
  backImage       String?
  rejectionReason String?
  verifiedAt      DateTime?
  verifiedBy      String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("kyc_documents")
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  userAgent    String?
  ipAddress    String?
  lastUsed     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Property {
  id            String   @id @default(uuid())
  slug          String   @unique
  title         String
  description   String
  price         Decimal  @db.Decimal(12, 2)
  pricePeriod   PricePeriod @default(TOTAL)
  currency      String   @default("KES")
  propertyType  PropertyType
  listingPurpose ListingPurpose?
  subType       String?
  status        PropertyStatus @default(AVAILABLE)

  moderationStatus ModerationStatus @default(DRAFT)
  reviewedAt       DateTime?
  reviewedBy       String?
  rejectionReason  String?

  address     String
  city        String
  region      String
  country     String   @default("Kenya")
  latitude    Decimal? @db.Decimal(10, 8)
  longitude   Decimal? @db.Decimal(11, 8)
  bedrooms    Int?
  bathrooms   Int?
  area        Int?
  features    String[]
  images      Json
  isPublished Boolean  @default(false)

  isFeatured  Boolean   @default(false)
  featuredUntil DateTime?
  expiresAt   DateTime?
  viewCount   Int       @default(0)
  impressionCount Int   @default(0)

  version     Int       @default(1)

  seoTitle       String?
  seoDescription String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  publishedAt   DateTime?
  deletedAt     DateTime?

  agent     User?   @relation(fields: [agentId], references: [id], onDelete: SetNull)
  agentId   String?

  commissions Commission[]
  payouts     PayoutProperty[]

  @@index([agentId])
  @@index([city, propertyType, moderationStatus])
  @@index([isPublished, status, createdAt])
  @@index([city, isPublished, price])
  @@index([moderationStatus])
  @@index([expiresAt])
  @@index([listingPurpose])

  @@map("properties")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  type      NotificationType
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@map("notifications")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  revoked   Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("refresh_tokens")
}

model AuditLog {
  id         String   @id @default(uuid())
  action     String
  entityType String
  entityId   String?
  oldData    Json?
  newData    Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  user   User?   @relation(fields: [userId], references: [id])
  userId String?

  @@map("audit_logs")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@map("password_reset_tokens")
}

enum OtpType {
  EMAIL_VERIFICATION
  PHONE_VERIFICATION
}

model OtpToken {
  id        String   @id @default(uuid())
  identifier String  // email or phone number
  token     String   // 6-digit code
  type      OtpType
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([identifier, type])
  @@map("otp_tokens")
}

model MagicLinkToken {
  id        String    @id @default(uuid())
  email     String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [email], references: [email])

  @@index([email])
  @@index([token])
  @@map("magic_link_tokens")
}

model ServiceCategory {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  icon        String?
  type        String   @default("BOTH")
  parentId    String?
  parent      ServiceCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    ServiceCategory[] @relation("CategoryHierarchy")
  createdAt   DateTime @default(now())

  serviceListings ServiceListing[]

  @@index([parentId])
  @@index([slug])
  @@map("service_categories")
}

model ServiceListing {
  id                String          @id @default(uuid())
  userId            String
  categoryId        String
  title             String
  description       String
  price             Decimal?        @db.Decimal(12, 2)
  currency          String          @default("KES")
  pricePeriod       PricePeriod     @default(TOTAL)
  location          String?
  city              String?
  region            String?
  images            Json?
  status            String          @default("ACTIVE")
  moderationStatus  ModerationStatus @default(DRAFT)
  viewCount         Int             @default(0)
  reviewedAt        DateTime?
  reviewedBy        String?
  rejectionReason   String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  category ServiceCategory @relation(fields: [categoryId], references: [id])

  @@index([userId])
  @@index([categoryId])
  @@index([city])
  @@index([status])
  @@index([moderationStatus])
  @@map("service_listings")
}

model Review {
  id         String   @id @default(uuid())
  userId     String
  targetType String
  targetId   String
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([targetType, targetId])
  @@index([userId])
  @@map("reviews")
}

model Commission {
  id                String    @id @default(uuid())
  referralPartnerId String?
  propertyId        String
  userId            String
  amount            Decimal   @default(0) @db.Decimal(12, 2)
  currency          String    @default("KES")
  status            String    @default("PENDING")
  paidAt            DateTime?
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  referralPartner ReferralPartner? @relation(fields: [referralPartnerId], references: [id], onDelete: Cascade)
  property        Property        @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  disputes        Dispute[]

  @@index([referralPartnerId])
  @@index([propertyId])
  @@index([userId])
  @@index([status])
  @@map("commissions")
}

model Payout {
  id                String    @id @default(uuid())
  referralPartnerId String?
  amount            Decimal   @db.Decimal(12, 2)
  currency          String    @default("KES")
  method            String    @default("MPESA")
  reference         String?
  status            String    @default("PENDING")
  notes             String?
  paidAt            DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  referralPartner ReferralPartner? @relation(fields: [referralPartnerId], references: [id], onDelete: Cascade)
  properties      PayoutProperty[]
  disputes        Dispute[]

  @@index([referralPartnerId])
  @@index([status])
  @@map("payouts")
}

model PayoutProperty {
  payoutId   String
  propertyId String
  payout     Payout   @relation(fields: [payoutId], references: [id], onDelete: Cascade)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@id([payoutId, propertyId])
  @@map("payout_properties")
}

model Dispute {
  id                String    @id @default(uuid())
  referralPartnerId String?
  commissionId      String?
  payoutId          String?
  title             String
  description       String
  amount            Decimal   @default(0) @db.Decimal(12, 2)
  currency          String    @default("KES")
  status            String    @default("PENDING")
  resolution        String?
  resolvedBy        String?
  resolvedAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  referralPartner ReferralPartner? @relation(fields: [referralPartnerId], references: [id], onDelete: Cascade)
  commission      Commission?     @relation(fields: [commissionId], references: [id], onDelete: SetNull)
  payout          Payout?         @relation(fields: [payoutId], references: [id], onDelete: SetNull)

  @@index([referralPartnerId])
  @@index([status])
  @@map("disputes")
}

model PaymentClaim {
  id                String    @id @default(uuid())
  referralPartnerId String?
  amount            Decimal   @db.Decimal(12, 2)
  currency          String    @default("KES")
  periodLabel       String?
  notes             String?
  status            String    @default("PENDING")
  adminNotes        String?
  reviewedById      String?
  reviewedAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  referralPartner ReferralPartner? @relation(fields: [referralPartnerId], references: [id], onDelete: Cascade)

  @@index([referralPartnerId])
  @@index([status])
  @@map("payment_claims")
}
